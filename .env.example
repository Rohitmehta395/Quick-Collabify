# -----------------------------------------------------------------------------
# .env.example
# This file serves as a template for all environment variables used in this
# monorepo. Copy this to ".env" to run the project locally.
# -----------------------------------------------------------------------------

# ==========================================
# GLOBAL SETTINGS
# ==========================================
NODE_ENV="development"

# ==========================================
# SECRETS & CONNECTIONS (DO NOT COMMIT REAL VALUES)
# ==========================================
# The main PostgreSQL database connection string
DATABASE_URL="postgres://username:password@localhost:5432/collab_db"

# The Redis instance used for WebSockets and Background Jobs
REDIS_URL="redis://localhost:6379"

# ==========================================
# PORTS & URLS
# ==========================================
# Port for apps/api (Express REST API)
PORT="3001"

# ==========================================
# FRONTEND VARIABLES (Must start with VITE_)
# ==========================================
VITE_API_URL="http://localhost:3001"
VITE_REALTIME_URL="http://localhost:3002"
