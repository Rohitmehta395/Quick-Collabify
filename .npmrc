# -------------------------------------------------------------------------
# .npmrc
# This file configures behavior for npm/pnpm. 
# -------------------------------------------------------------------------

# This forces pnpm to strictly check the "engines" field in our package.json.
# If a developer tries to install dependencies using an older version of Node 
# than what we require (Node >=20), the install will fail immediately. 
# This prevents hard-to-track bugs caused by wrong Node versions.
engine-strict=true
