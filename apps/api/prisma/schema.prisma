datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Trivial smoke-test model to verify migration pipelines work cleanly.
// This model will be replaced or expanded in future database architecture phases.
model SmokeTest {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}
